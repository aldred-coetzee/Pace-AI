# Withings config folder (optional)
# If set, looks for withings_app.json and .withings_user.json in this folder.
# If not set, uses the withings-sync library defaults (~/.withings_user.json).
# WITHINGS_CONFIG_FOLDER=/path/to/withings/config

# Server config (optional)
# WITHINGS_MCP_HOST=127.0.0.1
# WITHINGS_MCP_PORT=8004
